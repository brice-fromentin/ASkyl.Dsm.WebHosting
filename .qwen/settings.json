{
  "$version": 3,
  "mcpServers": {
    "web-search": {
      "args": [
        "-y",
        "open-websearch@latest"
      ],
      "command": "npx",
      "env": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa"
      },
      "timeout": 60000,
      "trust": true,
      "type": "stdio"
    }
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(coverlet *)",
      "Bash(curl *)",
      "Bash(dotnet *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(git add *)",
      "Bash(git add <specific-file>)",
      "Bash(git branch *)",
      "Bash(git diff)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull)",
      "Bash(git push)",
      "Bash(git remote *)",
      "Bash(git status)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(markdownlint *)",
      "Bash(mkdir *)",
      "Bash(sed *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Bash(git clean -f)",
      "Bash(git checkout -- .)",
      "Bash(git gc --prune)",
      "Bash(git reflog expire)",
      "Bash(git rebase --abort)",
      "Bash(git reset --hard)",
      "Bash(git reset --soft)"
    ]
  },
  "tools": {
    "approvalMode": "auto-edit"
  }
}