{
  "$version": 4,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$QWEN_PROJECT_DIR/.qwen/hooks/reinject-agents-standards.sh",
            "name": "reinject-agents-standards",
            "description": "Re-inject AGENTS.md into session context after compression",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "web-search": {
      "args": [
        "-y",
        "open-websearch@latest"
      ],
      "command": "npx",
      "env": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa"
      },
      "timeout": 60000,
      "trust": true,
      "type": "stdio"
    }
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(coverlet *)",
      "Bash(curl *)",
      "Bash(diff *)",
      "Bash(dotnet *)",
      "Bash(echo *)",
      "Bash(else)",
      "Bash(find *)",
      "Bash(fi)",
      "Bash(git add *)",
      "Bash(git add <specific-file>)",
      "Bash(git branch *)",
      "Bash(git diff)",
      "Bash(git fetch *)",
      "Bash(jq *)",
      "Bash(git log *)",
      "Bash(git pull)",
      "Bash(git push)",
      "Bash(git remote *)",
      "Bash(git status)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(markdownlint *)",
      "Bash(mkdir *)",
      "Bash(sed *)",
      "Bash(sleep *)",
      "Bash(sort)",
      "Bash(sort *)",
      "Bash(strings *)",
      "Bash(tail *)",
      "Bash(then)",
      "Bash(timeout *)",
      "Bash(true)",
      "Bash(wait *)"
    ],
    "deny": [
      "Bash(git clean -f)",
      "Bash(git checkout -- .)",
      "Bash(git gc --prune)",
      "Bash(git reflog expire)",
      "Bash(git rebase --abort)",
      "Bash(git reset --hard)",
      "Bash(git reset --soft)"
    ]
  },
  "tools": {
    "approvalMode": "auto-edit"
  }
}