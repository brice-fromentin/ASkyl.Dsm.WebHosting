# Root EditorConfig file for Askyl.Dsm.WebHosting
# See https://docs.microsoft.com/dotnet/fundamentals/code-analysis/configuration-options

is_root = true

# Global settings for all files
[*]
charset = utf-8-with-bom
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4

# C# specific settings
[*.cs]
indent_size = 4
tab_width = 4

# C# Code Style Rules
# See https://docs.microsoft.com/dotnet/fundamentals/code-analysis/style-rules

# Naming conventions
dot_naming_rules = true
dot_naming_rule.property_style = PascalCase
dot_naming_rule.method_style = PascalCase
dot_naming_rule.parameter_style = camelCase
dot_naming_rule.local_variable_style = camelCase
dot_naming_rule.field_style = camelCase
dot_naming_rule.type_parameter_style = PascalCase

# Braces - always use braces for control flow
dotnet_style_braces_for_control_flow_statements = true
dotnet_style_braces_for_if_else_when_single_line = false:warning

# Use var when type is obvious
dotnet_style_var_for_built_in_types = false:suggestion
dotnet_style_var_when_type_is_apparent = true:info

# Language keywords over type keywords (string vs String for types)
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access = false:none

# Modifier preferences
dotnet_style_require_accessibility_modifiers = forNonInterfaceMembers:warning

# Null check preferences
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

# Parentheses preferences
dotnet_style_parenthesized_condition_in_conditional_operator = false:none
dotnet_style_parentheses_in_arithmetic_binary_operators = alwaysForClarity:info
dotnet_style_parentheses_in_relational_binary_operators = alwaysForClarity:info

# Expression-level preferences
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = false:none
dotnet_style_prefer_conditional_expression_over_return = false:none
dotnet_style_prefer_null_check_over_type_check = true:suggestion

# Pattern matching preferences
dotnet_style_pattern_matching_over_is_with_cast_check = true:suggestion
dotnet_style_pattern_matching_over_as_with_null_check = true:suggestion

# LINQ preferences
dotnet_style_prefer_query_syntax = false:none
dotnet_style_prefer_collection_expression = true:info

# Simplification preferences
dotnet_simplify_interpolated_string = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# File header template (optional)
# dotnet_diagnostic.S125.severity = warning

# IDE00xx - Code style rules
IDE0005 = warning # Remove unnecessary whitespace
IDE0016 = warning # Use 'var' instead of explicit type (when appropriate)
IDE0045 = warning # Unnecessary semicolon at end of statement
IDE0055 = warning # Fix formatting

# CA rules - .NET Design Guidelines
CA1000 = none # Do not declare static members on general types (we use static for constants/extensions)
CA1051 = none # Do not declare visible instance fields (we have some legitimate uses)
CA1309 = warning # Use ordinal string comparison
CA1826 = warning # Do not use Enumerable methods on indexable collections

# Using directive organization
dotnet_sort_system_directives_first = true:warning
dotnet_sort_using_statements = true:warning

# Roslynator using directive ordering (System → Microsoft → Third-party → Project)
roslynator_order_using_directives_severity = error
roslynator_group_using_directives_severity = error
roslynator_remove_unnecessary_using_directives_severity = warning
roslynator_add_missing_using_directives_severity = info

# Blank line rules (limited support in editorconfig)
# Note: Full blank line enforcement requires custom analyzer or dotnet-format

# Magic numbers/strings detection
CA1303 = warning # Do not pass literals as localized parameters
CA1861 = suggestion # Prefer 'static' members over repeated string allocation

# Logging style (custom rules - limited native support)
# Single-line logging enforcement requires custom analyzer

# Nullable reference types
dotnet_style_nullable_reference_types = enable:error

# Additional C# 14 / .NET 10 specific settings
dotnet_style_prefer_collection_expression = true:suggestion
dotnet_style_primary_constructors = true:info
