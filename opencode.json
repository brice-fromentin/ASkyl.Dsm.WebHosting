{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "lsp": true,
  "instructions": ["AGENTS.md"],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 15
  },
  "references": {
    "docs": {
      "path": "docs/ai",
      "description": "AI-generated documentation including technical architecture"
    }
  },
  "tool_output": {
    "max_lines": 200
  },
  "watcher": {
    "ignore": ["**/bin/**", "**/obj/**", "**/packages/**"]
  },
  "formatter": true,
  "experimental": {
    "batch_tool": true
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "bash": {
      "*": "ask",
      "awk *": "allow",
      "base64 *": "allow",
      "brew info *": "allow",
      "brew list *": "allow",
      "cat *": "allow",
      "command -v *": "allow",
      "coverlet *": "allow",
      "curl *": "allow",
      "cut *": "allow",
      "date *": "allow",
      "df *": "allow",
      "diff *": "allow",
      "dig *": "allow",
      "dotnet *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env": "allow",
      "file *": "allow",
      "find *": "allow",
      "git add *": "ask",
      "git branch": "allow",
      "git branch *": "allow",
      "git checkout -- .": "deny",
      "git clean -f*": "deny",
      "git commit *": "ask",
      "git diff *": "allow",
      "git gc --prune*": "deny",
      "git log *": "allow",
      "git push *": "ask",
      "git reflog expire*": "deny",
      "git rebase --abort": "deny",
      "git reset --hard*": "deny",
      "git reset --soft*": "deny",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git stash list *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hexdump *": "allow",
      "hostname": "allow",
      "id *": "allow",
      "jq *": "allow",
      "lsof *": "allow",
      "ls *": "allow",
      "markdownlint *": "allow",
      "mdfind *": "allow",
      "mdls *": "allow",
      "mkdir *": "allow",
      "netstat *": "allow",
      "nslookup *": "allow",
      "npm list *": "allow",
      "npm view *": "allow",
      "od *": "allow",
      "pbpaste": "allow",
      "ping *": "allow",
      "printenv *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "ss *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "sw_vers": "allow",
      "tar -t *": "allow",
      "tar -x *": "allow",
      "tail *": "allow",
      "timeout *": "allow",
      "tput *": "allow",
      "tree *": "allow",
      "tr *": "allow",
      "true": "allow",
      "uname *": "allow",
      "unzip -l *": "allow",
      "uptime": "allow",
      "wc *": "allow",
      "whoami": "allow",
      "which *": "allow",
      "wait *": "allow",
      "xxd *": "allow",
      "zipinfo *": "allow"
    }
  }
}