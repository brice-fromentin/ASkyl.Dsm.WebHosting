{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "command -v *": "allow",
      "coverlet *": "allow",
      "curl *": "allow",
      "df *": "allow",
      "diff *": "allow",
      "dotnet *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "find *": "allow",
      "git add *": "ask",
      "git branch *": "allow",
      "git branch": "allow",
      "git checkout -- .": "deny",
      "git clean -f*": "deny",
      "git commit *": "ask",
      "git diff": "allow",
      "git gc --prune*": "deny",
      "git log": "allow",
      "git push *": "ask",
      "git reflog expire*": "deny",
      "git rebase --abort": "deny",
      "git reset --hard*": "deny",
      "git reset --soft*": "deny",
      "git status": "allow",
      "jq *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "markdownlint *": "allow",
      "mkdir *": "allow",
      "od *": "allow",
      "printenv *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "timeout *": "allow",
      "true": "allow",
      "uname *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "wait *": "allow"
    }
  }
}