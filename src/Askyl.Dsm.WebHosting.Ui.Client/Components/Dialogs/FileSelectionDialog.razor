@using Askyl.Dsm.WebHosting.Constants.UI
@using Askyl.Dsm.WebHosting.Data.Domain.FileSystem
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization

@implements IDialogContentComponent
@implements IWorkingState

@inject IDialogService DialogService
@inject IFileSystemService FileSystemService
@inject ITreeContentService TreeContentService
@inject IJSRuntime JSRuntime
@inject ILocalizer localizer

<LoadingOverlay WorkingStateComponent="@this" />

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.H2">@localizer[L.FileSelection.DialogTitle]</FluentLabel>
</FluentDialogHeader>

<FluentDialogBody>
    <FluentSplitter Orientation="Orientation.Horizontal" Panel1Size="30%" Panel1MinSize="20%" Panel1MaxSize="50%" Class="file-dialog-splitter">
        <Panel1>
            <div class="full-size file-dialog-tree">
                <FluentTreeView Items="@TreeItems" LazyLoadItems="true" @bind-SelectedItem="@SelectedTreeItem" OnSelectedChange="OnTreeItemSelectionChanged" />
            </div>
        </Panel1>
        <Panel2>
            <AutoDataGrid TItem="FsEntry" Items="@_files" GridTemplateColumns="1fr auto auto auto" OnRowClick="@OnFileClick" OnRowDoubleClick="@OnFileDoubleClick" OnReload="@ReloadCurrentDirectory">
                <ChildContent>
                    <TemplateColumn TGridItem="FsEntry" Title="@localizer[L.Home.GridColumnName]" Sortable="true" SortBy="GridSort<FsEntry>.ByAscending(f => f.Name)" InitialSortDirection="SortDirection.Ascending">
                        <ChildContent Context="file">
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                                <FluentIcon Value="@GetFileIcon(file)" />
                                <FluentLabel Class="file-name-label">@file.Name</FluentLabel>
                            </FluentStack>
                        </ChildContent>
                    </TemplateColumn>
                    <TemplateColumn TGridItem="FsEntry" Title="@localizer[L.Common.Size]" Align="Align.End" Sortable="true" SortBy="GridSort<FsEntry>.ByAscending(f => f.Size ?? 0)">
                        @(GetFileSize(context, localizer))
                    </TemplateColumn>
                    <TemplateColumn TGridItem="FsEntry" Title="@localizer[L.Common.Type]" Align="Align.Center" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Ascending">
                        @(GetFileType(context, localizer))
                    </TemplateColumn>
                    <PropertyColumn TGridItem="FsEntry" TProp="DateTime?" Title="@localizer[L.Common.Modified]" Property="@(f => f.Modified)" Format="g" Align="Align.Center" Sortable="true" />
                </ChildContent>

                <EmptyContent>
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center">
                        @if (!String.IsNullOrEmpty(_selectedPath))
                        {
                            <FluentLabel>@localizer[L.FileSelection.NoFilesFound]</FluentLabel>
                        }
                        else
                        {
                            <FluentLabel>@localizer[L.FileSelection.SelectFolder]</FluentLabel>
                        }
                    </FluentStack>
                </EmptyContent>
            </AutoDataGrid>
        </Panel2>
    </FluentSplitter>
</FluentDialogBody>

<FluentDialogFooter>
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.End">
        <FluentButton OnClick="CancelAsync" Appearance="Appearance.Neutral">
            @localizer[L.Common.Cancel]
        </FluentButton>
        <FluentButton OnClick="ConfirmAsync" Appearance="Appearance.Accent" Disabled="@(_selectedFile == null)">
            @localizer[L.FileSelection.SelectFile]
        </FluentButton>
    </FluentStack>
</FluentDialogFooter>

@code
{
    #region Parameters

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    [Parameter]
    public EventCallback<FsEntry> OnFileSelected { get; set; }

    #endregion

    #region Private Fields

    private List<TreeViewItem> TreeItems { get; set; } = [];
    private IQueryable<FsEntry> _files = AutoDataGrid<FsEntry>.Empty();
    private string? _selectedPath;
    private FsEntry? _selectedFile;
    private ITreeViewItem? SelectedTreeItem { get; set; }

    #endregion

    #region IWorkingState Implementation

    public bool IsWorking { get; set; }
    public string Message { get; set; } = String.Empty;

    public void NotifyStateChanged() => StateHasChanged();

    #endregion

    #region Lifecycle

    protected override async Task OnInitializedAsync() => await LoadSharedFoldersAsync();

    #endregion

    #region Tree Management

    private async Task LoadSharedFoldersAsync()
    {
        using var worker = this.CreateWorkingState(localizer[L.Loading.SharedFolders]);

        try
        {
            var sharedFoldersResult = await FileSystemService.GetSharedFoldersAsync();

            if (!sharedFoldersResult.Success)
            {
                await ShowErrorAsync(sharedFoldersResult.Message ?? localizer[L.Error.FailedToLoadSharedFolders]);
                TreeItems = [];
                return;
            }

            var sharedFolders = sharedFoldersResult.Value ?? [];
            TreeItems = sharedFolders.ToTreeViewItems(LoadChildDirectoriesAsync);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex.Message);
            TreeItems = [];
        }
    }

    private async Task<List<TreeViewItem>> LoadChildDirectoriesAsync(string path)
    {
        try
        {
            // Pass the same callback for nested lazy loading
            return await TreeContentService.LoadChildDirectoriesAsync(path, ShowErrorAsync, LoadChildDirectoriesAsync);
        }
        catch
        {
            return [];
        }
    }

    private async Task OnTreeItemSelectionChanged(FluentTreeItem selectedItem)
    {
        if (!selectedItem.Selected || selectedItem.Id is not string path)
        {
            return;
        }

        await LoadDirectoryContentsAsync(path);
    }

    #endregion

    #region File Management

    private async Task LoadDirectoryContentsAsync(string? selectedPath)
    {
        _selectedPath = selectedPath;
        _selectedFile = null;

        if (String.IsNullOrEmpty(selectedPath))
        {
            _files = AutoDataGrid<FsEntry>.Empty();
            return;
        }

        using var worker = this.CreateWorkingState(localizer[L.Loading.DirectoryContents]);

        try
        {
            var contentsResult = await FileSystemService.GetDirectoryContentsAsync(selectedPath, false);

            if (!contentsResult.Success)
            {
                await HandleDirectoryLoadErrorAsync(contentsResult.Message ?? localizer[L.Error.FailedToLoadDirectoryContents]);
                return;
            }

            _files = contentsResult.Value!.AsQueryable();
        }
        catch (Exception ex)
        {
            await HandleDirectoryLoadErrorAsync($"{localizer[L.Error.FailedToLoadDirectoryContents]}: {ex.Message}");
        }
    }

    private void OnFileClick(FsEntry file)
    {
        if (file.IsDirectory)
        {
            return;
        }

        _selectedFile = file;
        StateHasChanged();
    }

    private async Task OnFileDoubleClick(FsEntry file)
    {
        if (file.IsDirectory)
        {
            await JSRuntime.InvokeVoidAsync("selectChildItem", file.Path, Path.GetDirectoryName(file.Path));
            return;
        }

        _selectedFile = file;
        await ConfirmAsync();
    }

    private async Task NavigateToDirectoryAsync(string directoryPath)
    {
        await LoadDirectoryContentsAsync(directoryPath);
    }

    private async Task ReloadCurrentDirectory() => await LoadDirectoryContentsAsync(_selectedPath);

    #endregion

    #region Error Handling

    private async Task ShowErrorAsync(string error) => await DialogService.ShowErrorAsync(error);

    private async Task HandleDirectoryLoadErrorAsync(string errorMessage)
    {
        _files = AutoDataGrid<FsEntry>.Empty();
        await ShowErrorAsync(errorMessage);
    }

    #endregion

    #region Dialog Actions

    private async Task ConfirmAsync()
    {
        if (_selectedFile is not null)
        {
            await OnFileSelected.InvokeAsync(_selectedFile);
            await Dialog.CloseAsync(_selectedFile);
        }
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    #endregion

    #region Display Helpers

    private static string GetFileSize(FsEntry file, ILocalizer localizer)
    {
        if (file.IsDirectory || file.Size is null)
        {
            return localizer[L.Common.Dash];
        }

        var bytes = file.Size.Value;

        if (bytes < FileSizeConstants.BytesPerKibibyte)
        {
            return $"{bytes} {FileSizeConstants.BytesSuffix}";
        }

        if (bytes < FileSizeConstants.BytesPerMebibyte)
        {
            return $"{((double)bytes / FileSizeConstants.BytesPerKibibyte).ToString(FileSizeConstants.DecimalFormat)} {FileSizeConstants.KibibytesSuffix}";
        }

        if (bytes < FileSizeConstants.BytesPerGibibyte)
        {
            return $"{((double)bytes / FileSizeConstants.BytesPerMebibyte).ToString(FileSizeConstants.DecimalFormat)} {FileSizeConstants.MebibytesSuffix}";
        }

        return $"{((double)bytes / FileSizeConstants.BytesPerGibibyte).ToString(FileSizeConstants.DecimalFormat)} {FileSizeConstants.GibibytesSuffix}";
    }

    private static string GetFileType(FsEntry file, ILocalizer localizer) => file.IsDirectory ? localizer[L.FileSelection.Directory] : localizer[L.FileSelection.File];

    private static Icon GetFileIcon(FsEntry file)
    {
        if (file.IsDirectory)
        {
            return new IconsRegular16.Folder();
        }

        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        return extension switch
        {
            ".txt" or ".md" or ".log" => new IconsRegular16.Document(),
            ".pdf" => new IconsRegular16.DocumentPdf(),
            ".doc" or ".docx" => new IconsRegular16.DocumentText(),
            ".xls" or ".xlsx" => new IconsRegular16.DocumentTable(),
            ".ppt" or ".pptx" => new IconsRegular16.SlideText(),
            ".zip" or ".rar" or ".7z" or ".tar" or ".gz" => new IconsRegular16.FolderZip(),
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" or ".webp" => new IconsRegular16.Image(),
            ".mp4" or ".avi" or ".mov" or ".wmv" or ".flv" or ".mkv" => new IconsRegular16.Video(),
            ".mp3" or ".wav" or ".flac" or ".aac" or ".ogg" => new IconsRegular16.MusicNote2(),
            ".html" or ".htm" or ".css" or ".js" or ".ts" or ".json" => new IconsRegular16.Code(),
            ".cs" or ".vb" or ".cpp" or ".c" or ".h" or ".java" or ".py" or ".php" => new IconsRegular16.CodeBlock(),
            ".xml" or ".config" or ".ini" or ".cfg" => new IconsRegular16.DocumentSettings(),
            _ => new IconsRegular16.Document()
        };
    }

    #endregion

}