@using Askyl.Dsm.WebHosting.Constants.Network
@using Askyl.Dsm.WebHosting.Constants.UI
@using Askyl.Dsm.WebHosting.Data.Domain.FileSystem
@using Askyl.Dsm.WebHosting.Data.Domain.WebSites
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization

@inherits WorkingStateBase
@implements IDialogContentComponent

@using Askyl.Dsm.WebHosting.Ui.Client.Components.Patterns.WorkingState
@inject IDialogService DialogService
@inject IWebSiteHostingService HostingService
@inject ILocalizer localizer

<LoadingOverlay WorkingStateComponent="@this" OnStateChanged="StateHasChanged" />

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.H2">@(IsEditMode ? localizer[LK.WebsiteConfig.EditTitle] : localizer[LK.WebsiteConfig.AddTitle])</FluentLabel>
</FluentDialogHeader>

<FluentDialogBody @onkeydown:Enter="OnEnterKeyAsync">
    <EditForm Model="@Configuration" OnValidSubmit="ConfirmAsync">
        <FluentValidator />
        <FluentStack Orientation="Orientation.Vertical">
            <RealTimeTextField @bind-Value="Configuration.Name" Label="@localizer[LK.WebsiteConfig.NameLabel]" Class="full-size" Autofocus="true" />
            <FluentValidationMessage For="@(() => Configuration.Name)" />

            <FluentDivider />
            <FluentLabel Typo="Typography.H3">@localizer[LK.WebsiteConfig.AppSettingsSection]</FluentLabel>

            <FluentStack Orientation="Orientation.Vertical">
                <FluentLabel>@localizer[LK.WebsiteConfig.AppPathLabel]</FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal">
                    <RealTimeTextField @bind-Value="Configuration.ApplicationPath" Class="flex-full-width" />
                    <FluentButton IconStart="@(new IconsRegular20.FolderOpen())" Appearance="Appearance.Outline" OnClick="SelectApplicationPath" Type="ButtonType.Button" />
                </FluentStack>
            </FluentStack>
            <FluentValidationMessage For="@(() => Configuration.ApplicationPath)" />
            <FluentStack Orientation="Orientation.Horizontal">
                <FluentStack Orientation="Orientation.Vertical" Class="flex-full-width">
                    <RealTimeTextField @bind-Value="Configuration.Environment" Label="@localizer[LK.WebsiteConfig.EnvironmentLabel]" Class="full-size" />
                    <FluentValidationMessage For="@(() => Configuration.Environment)" />
                </FluentStack>
                <FluentStack Orientation="Orientation.Vertical" Class="flex-full-width">
                    <RealTimeNumberField @bind-Value="Configuration.InternalPort" Label="@localizer[LK.WebsiteConfig.InternalPortLabel]" Class="full-size" />
                    <FluentValidationMessage For="@(() => Configuration.InternalPort)" />
                </FluentStack>
            </FluentStack>
            <RealTimeNumberField @bind-Value="Configuration.ProcessTimeoutSeconds" Label="@localizer[LK.WebsiteConfig.ShutdownTimeoutLabel]" Class="full-size" />
            <FluentValidationMessage For="@(() => Configuration.ProcessTimeoutSeconds)" />
            <FluentCheckbox @bind-Value="Configuration.IsEnabled" Label="@localizer[LK.WebsiteConfig.EnabledLabel]" />
            <FluentCheckbox @bind-Value="Configuration.AutoStart" Label="@localizer[LK.WebsiteConfig.AutoStartLabel]" />

            <FluentDivider />
            <FluentLabel Typo="Typography.H3">@localizer[LK.WebsiteConfig.ReverseProxySection]</FluentLabel>

            <RealTimeTextField @bind-Value="Configuration.HostName" Label="@localizer[LK.WebsiteConfig.HostnameLabel]" Class="full-size" />
            <FluentValidationMessage For="@(() => Configuration.HostName)" />
            <FluentStack Orientation="Orientation.Horizontal">
                <FluentStack Orientation="Orientation.Vertical" Class="flex-full-width">
                    <FluentSelect TOption="string" @bind-Value="ProtocolProxy" Label="@localizer[LK.WebsiteConfig.ProtocolLabel]" Class="full-size">
                        @foreach (var protocol in Enum.GetValues<ProtocolType>())
                        {
                            <FluentOption Value="@(((int)protocol).ToString())">@localizer[protocol switch { ProtocolType.HTTP => LK.WebsiteConfig.ProtocolHttp, ProtocolType.HTTPS => LK.WebsiteConfig.ProtocolHttps, _ => protocol.ToString() }]</FluentOption>
                        }
                    </FluentSelect>
                    <FluentValidationMessage For="@(() => Configuration.Protocol)" />
                </FluentStack>
                <FluentStack Orientation="Orientation.Vertical" Class="flex-full-width">
                    <RealTimeNumberField @bind-Value="Configuration.PublicPort" Label="@localizer[LK.WebsiteConfig.PublicPortLabel]" Class="full-size" />
                    <FluentValidationMessage For="@(() => Configuration.PublicPort)" />
                </FluentStack>
            </FluentStack>
            <FluentCheckbox @bind-Value="Configuration.EnableHSTS" Label="@localizer[LK.WebsiteConfig.EnableHSTSLabel]" />
        </FluentStack>
        <div class="fluent-dialog-footer">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton OnClick="CancelAsync" Appearance="Appearance.Neutral" Type="ButtonType.Button">
                    @localizer[LK.Common.Cancel]
                </FluentButton>
                <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">
                    @(IsEditMode ? localizer[LK.WebsiteConfig.UpdateButton] : localizer[LK.WebsiteConfig.CreateButton])
                </FluentButton>
            </FluentStack>
        </div>
    </EditForm>
</FluentDialogBody>

@code
{
    #region Parameters

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    [Parameter]
    public WebSiteInstance Content { get; set; } = default!;

    #endregion

    #region Properties and Fields

    private WebSiteConfiguration Configuration { get; set; } = default!;

    private bool IsEditMode => Content?.Configuration?.Id != Guid.Empty;

    private string ProtocolProxy
    {
        get => ((int)Configuration.Protocol).ToString();
        set
        {
            if (Enum.TryParse<ProtocolType>(value, out var protocol))
            {
                Configuration.Protocol = protocol;
            }
        }
    }

    #endregion

    public override void NotifyStateChanged() => StateHasChanged();

    #region Lifecycle

    protected override void OnInitialized()
    {
        Configuration = Content?.Configuration ?? new();
    }

    #endregion

    #region Dialog Actions

    private async Task SelectApplicationPath()
    {
        var parameters = new DialogParameters { Width = DialogConstants.WidthLarge, Modal = true, TrapFocus = false, PreventScroll = true, PreventDismissOnOverlayClick = true };
        var dialog = await DialogService.ShowDialogAsync<FileSelectionDialog>(parameters);
        var result = await dialog.Result;

        if (result.Cancelled || result.Data is not FsEntry selectedFile)
        {
            return;
        }

        Configuration.ApplicationPath = selectedFile.Path;
        Configuration.ApplicationRealPath = selectedFile.RealPath;
    }

    /// <summary>
    /// Handles Enter key press to trigger form submission.
    /// </summary>
    private async Task OnEnterKeyAsync() => await ConfirmAsync();

    private async Task ConfirmAsync()
    {
        try
        {
            if (String.IsNullOrEmpty(Configuration.ApplicationRealPath))
            {
                await DialogService.ShowErrorAsync(localizer[LK.Error.ApplicationPathRequired]);
                return;
            }

           using var worker = this.CreateWorkingState(localizer[IsEditMode ? LK.Loading.UpdatingWebsite : LK.Loading.CreatingWebsite, Configuration.Name]);

            var result = IsEditMode
                ? await HostingService.UpdateWebsiteAsync(Configuration)
                : await HostingService.AddWebsiteAsync(Configuration);

            if (!result.Success)
            {
                await DialogService.ShowErrorAsync($"{localizer[LK.Error.OperationFailed]}: {result.Message}");
                return;
            }

            if (!String.IsNullOrEmpty(result.WarningMessage) && result.Value?.RequiredFramework is string channel)
            {
                var confirmMessage = localizer[LK.WebsiteConfig.FrameworkNotInstalled, channel];
                var confirm = await DialogService.ShowConfirmationAsync(confirmMessage);
                var confirmResult = await confirm.Result;

                if (confirmResult is { Cancelled: false })
                {
                    await ShowAspNetReleasesDialogAsync(channel);
                }
            }

            await Dialog.CloseAsync();
        }
        catch (Exception ex)
        {
            var action = localizer[IsEditMode ? LK.WebsiteConfig.ActionUpdating : LK.WebsiteConfig.ActionCreating];
            await DialogService.ShowErrorAsync(localizer[LK.WebsiteConfig.ErrorModifying, action, ex.Message]);
        }
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task ShowAspNetReleasesDialogAsync(string channel)
    {
        var parameters = new DialogParameters { Width = DialogConstants.WidthAuto, Modal = true, TrapFocus = false, PreventScroll = true, PreventDismissOnOverlayClick = true };
        await DialogService.ShowDialogAsync<AspNetReleasesDialog>(channel, parameters);
    }

    #endregion
}
