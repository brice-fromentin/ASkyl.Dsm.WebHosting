@using Askyl.Dsm.WebHosting.Data.Domain.Runtime
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization
@using Askyl.Dsm.WebHosting.Logging

@implements IDialogContentComponent
@implements IWorkingState

@inject IDialogService DialogService
@inject IDotnetVersionService DotnetVersionService
@inject IFrameworkManagementService ManagementService
@inject IToastService ToastService
@inject ILogger<ILogAspNetReleasesDialog> Logger
@inject ILocalizer localizer

<LoadingOverlay WorkingStateComponent="@this" />

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.H2">@localizer[L.AspNetReleases.DialogTitle]</FluentLabel>
</FluentDialogHeader>

<FluentDialogFooter>
    <FluentButton OnClick="CancelAsync" Appearance="Appearance.Accent" Disabled="@IsWorking" Class="flex-full-width">@localizer[L.Common.Close]</FluentButton>
</FluentDialogFooter>

<FluentDialogBody>
    <FluentToolbar Class="full-width">
        <FluentLabel>@localizer[L.AspNetReleases.ChannelLabel]</FluentLabel>

        <FluentSelect TOption="AspNetChannel" Items="@Channels" SelectedOption="@SelectedChannel" SelectedOptionChanged="OnChannelChanged" Width="140px" Disabled="@IsWorking" />

        <FluentButton OnClick="Refresh" Appearance="Appearance.Outline" Title="@localizer[L.Common.Refresh]" Disabled="@IsWorking">
            <FluentIcon Value="@(new IconsRegular16.ArrowClockwise())" />
        </FluentButton>

        <FluentButton OnClick="@(IsSelectedVersionInstalled ? UninstallSelectedFramework : InstallSelectedFramework)" Appearance="Appearance.Accent" Disabled="@(!CanProcessSelected || IsWorking)" Class="flex-full-width">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(IsSelectedVersionInstalled ? (Icon)new IconsRegular16.Delete() : new IconsRegular16.CloudArrowDown())" Color="Color.Fill" />
                <FluentLabel Color="Color.Fill">
                    @GetActionButtonText()
                </FluentLabel>
            </FluentStack>
        </FluentButton>
    </FluentToolbar>

    <div class="dialog-grid-container">
        <AutoDataGrid TItem="AspNetRelease" Items="@Releases" GridTemplateColumns="240px 120px 100px 120px" OnRowClick="@OnReleaseSelected" OnReload="@ReloadReleases">
            <ChildContent>
                <PropertyColumn TGridItem="AspNetRelease" TProp="string" Title="@localizer[L.AspNetReleases.GridColumnVersion]" Property="@(r => r.Version)" Sortable="true" />
                <TemplateColumn TGridItem="AspNetRelease" Title="@localizer[L.AspNetReleases.GridColumnInstalled]" Align="Align.Center">
                    @(context.IsInstalled ? localizer[L.Common.CheckMark] : String.Empty)
                </TemplateColumn>
                <TemplateColumn TGridItem="AspNetRelease" Title="@localizer[L.AspNetReleases.GridColumnSecurity]" Align="Align.Center">
                    @(context.IsSecurity ? localizer[L.Common.WarningIcon] : String.Empty)
                </TemplateColumn>
                <PropertyColumn TGridItem="AspNetRelease" TProp="DateTimeOffset?" Title="@localizer[L.AspNetReleases.GridColumnRelease]" Property="@(r => r.ReleaseDate)" Format="d" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Descending" />
            </ChildContent>
        </AutoDataGrid>
    </div>
</FluentDialogBody>

@code
{
    #region IWorkingState Implementation

    public bool IsWorking { get; set; }

    public string Message { get; set; } = String.Empty;

    public void NotifyStateChanged() => StateHasChanged();

    #endregion

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    /// <summary>
    /// Gets or sets the product version of the channel to pre-select (e.g., "9.0").
    /// </summary>
    [Parameter]
    public string? Content { get; set; }

    private List<AspNetChannel> Channels { get; set; } = [];

    private IQueryable<AspNetRelease> Releases { get; set; } = AutoDataGrid<AspNetRelease>.Empty();

    private AspNetChannel? SelectedChannel { get; set; }

    private AspNetRelease? SelectedItem { get; set; }

    private bool _channelsLoaded;

    #region Computed Properties

    private bool IsSelectedVersionInstalled => SelectedItem?.IsInstalled == true;

    private bool CanProcessSelected => !IsWorking && SelectedItem != null;

    private bool CanInstallSelected => !IsWorking && SelectedItem != null && !SelectedItem.IsInstalled;

    private string GetActionButtonText()
    {
        if (SelectedItem == null)
        {
            return localizer[L.AspNetReleases.SelectVersion];
        }

        return IsSelectedVersionInstalled
            ? localizer[L.AspNetReleases.UninstallVersion, SelectedItem.Version]
            : localizer[L.AspNetReleases.InstallVersion, SelectedItem.Version];
    }

    #endregion

    protected override async Task OnParametersSetAsync()
    {
        if (_channelsLoaded)
        {
            return;
        }

        _channelsLoaded = true;
        await LoadChannelsAsync();
    }

    private void OnReleaseSelected(AspNetRelease release)
    {
        SelectedItem = release;
        StateHasChanged();
    }

    private async Task OnChannelChanged(AspNetChannel? channel)
    {
        SelectedChannel = channel;
        await LoadReleasesAsync(channel);
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task LoadChannelsAsync()
    {
        try
        {
            var channelsResult = await DotnetVersionService.GetChannelsAsync();

            if (!channelsResult.Success)
            {
                await ShowErrorAsync(channelsResult.Message ?? localizer[L.Error.FailedToLoadChannels]);
                Channels.Clear();
                SelectedChannel = null;
                return;
            }

            Channels = channelsResult.Value ?? [];

            var initialChannel = Channels.FirstOrDefault(c => c.ProductVersion == Content)
                ?? SelectedChannel
                ?? Channels.FirstOrDefault();
            await OnChannelChanged(initialChannel);
        }
        catch (Exception ex)
        {
            Logger.FailedToLoadChannels(ex);
            await ShowErrorAsync(ex.Message);
            Channels.Clear();
            SelectedChannel = null;
        }
    }

    private async Task LoadReleasesAsync(AspNetChannel? channel)
    {
        SelectedItem = null;

        if (channel == null)
        {
            Releases = AutoDataGrid<AspNetRelease>.Empty();
            return;
        }

        try
        {
            var releasesResult = await DotnetVersionService.GetReleasesWithStatusAsync(channel.ProductVersion);

            if (!releasesResult.Success)
            {
                await ShowErrorAsync(releasesResult.Message ?? localizer[L.Error.FailedToLoadReleases]);
                Releases = AutoDataGrid<AspNetRelease>.Empty();
                return;
            }

            var releases = releasesResult.Value ?? [];
            Releases = releases.AsQueryable();
        }
        catch (Exception ex)
        {
            Logger.FailedToLoadReleases(ex, channel?.ProductVersion);
            await ShowErrorAsync(ex.Message);
            Releases = AutoDataGrid<AspNetRelease>.Empty();
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task Refresh() => await LoadChannelsAsync();

    private async Task ReloadReleases() => await LoadReleasesAsync(SelectedChannel);

    private async Task ShowErrorAsync(string error) => await DialogService.ShowErrorAsync(error);

    private async Task InstallSelectedFramework()
    {
        if (!CanInstallSelected || SelectedItem == null)
        {
            return;
        }

        try
        {
            using var worker = this.CreateWorkingState(localizer[L.Loading.Installing]);

            var result = await ManagementService.InstallFrameworkAsync(SelectedItem.Version, SelectedChannel?.ProductVersion ?? String.Empty);

            if (result.Success)
            {
                await DialogService.ShowInfoAsync(result.Message ?? localizer[L.Success.InstallationCompleted]);
                await Refresh();
            }
            else
            {
                await DialogService.ShowErrorAsync(result.Message ?? localizer[L.Error.InstallationFailed]);
            }
        }
        catch (Exception ex)
        {
            Logger.InstallationError(ex, SelectedItem?.Version);
            await DialogService.ShowErrorAsync(localizer[L.AspNetReleases.InstallationError, ex.Message]);
        }
    }

    private async Task UninstallSelectedFramework()
    {
        if (!IsSelectedVersionInstalled || SelectedItem == null)
        {
            return;
        }

        var confirmationMessage = localizer[L.AspNetReleases.UninstallConfirmation, SelectedItem.Version];
        var confirmation = await DialogService.ShowConfirmationAsync(confirmationMessage);
        var result = await confirmation.Result;

        if (result == null || result.Cancelled)
        {
            return;
        }

        try
        {
            using var worker = this.CreateWorkingState(localizer[L.Loading.Uninstalling]);

            var uninstallResult = await ManagementService.UninstallFrameworkAsync(SelectedItem.Version);

            if (uninstallResult.Success)
            {
                await DialogService.ShowInfoAsync(uninstallResult.Message ?? localizer[L.Success.UninstallationCompleted]);
                await Refresh();
            }
            else
            {
                await DialogService.ShowErrorAsync(uninstallResult.Message ?? localizer[L.Error.UninstallationFailed]);
            }
        }
        catch (Exception ex)
        {
            Logger.UninstallationError(ex, SelectedItem?.Version);
            await DialogService.ShowErrorAsync(localizer[L.AspNetReleases.UninstallationError, ex.Message]);
        }
    }
}