@using Askyl.Dsm.WebHosting.Data.Domain.Licensing
@using Askyl.Dsm.WebHosting.Globalization

@inherits WorkingStateBase
@implements IDialogContentComponent

@using Askyl.Dsm.WebHosting.Ui.Client.Components.Patterns.WorkingState
@inject ILicenseService LicenseService
@inject ILocalizer localizer

<LoadingOverlay WorkingStateComponent="@this" OnStateChanged="StateHasChanged" />

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.H2">@localizer[LK.Licenses.DialogTitle]</FluentLabel>
</FluentDialogHeader>

<FluentDialogFooter>
    <FluentButton OnClick="CancelAsync" Appearance="Appearance.Accent" Class="flex-full-width">@localizer[LK.Common.Close]</FluentButton>
</FluentDialogFooter>

<FluentDialogBody>
    @if (_licenses is not null)
    {
        <FluentTabs Orientation="Orientation.Vertical" Class="full-size">
            @foreach (var license in _licenses)
            {
                <FluentTab>
                    <Header>@license.Name</Header>
                    <ChildContent>
                        <pre>@license.Content</pre>
                    </ChildContent>
                </FluentTab>
            }
        </FluentTabs>
    }
    else
    {
        <FluentProgressRing />
    }
</FluentDialogBody>

@code
{
    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    private IReadOnlyList<LicenseInfo>? _licenses;

    protected override async Task OnInitializedAsync()
    {
        using var worker = this.CreateWorkingState(localizer[LK.Licenses.Loading]);

        _licenses = await LicenseService.GetLicensesAsync();
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();
}