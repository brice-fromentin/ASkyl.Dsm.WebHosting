@using Askyl.Dsm.WebHosting.Data.Domain.Licensing
@using Askyl.Dsm.WebHosting.Globalization
@using Askyl.Dsm.WebHosting.Globalization.Resources
@using Microsoft.Extensions.Localization

@implements IDialogContentComponent
@implements IWorkingState

@inject ILicenseService LicenseService
@inject IStringLocalizer<SharedResource> localizer

<LoadingOverlay WorkingStateComponent="@this" />

<FluentDialogHeader ShowDismiss="true">
    <FluentLabel Typo="Typography.H2">@localizer[L.Licenses.DialogTitle]</FluentLabel>
</FluentDialogHeader>

<FluentDialogFooter>
    <FluentButton OnClick="CancelAsync" Appearance="Appearance.Accent" Class="flex-full-width">@localizer[L.Common.Close]</FluentButton>
</FluentDialogFooter>

<FluentDialogBody>
    @if (_licenses is not null)
    {
        <FluentTabs Orientation="Orientation.Vertical" Class="full-size">
            @foreach (var license in _licenses)
            {
                <FluentTab>
                    <Header>@license.Name</Header>
                    <ChildContent>
                        <pre>@license.Content</pre>
                    </ChildContent>
                </FluentTab>
            }
        </FluentTabs>
    }
    else
    {
        <FluentProgressRing />
    }
</FluentDialogBody>

@code
{
    #region IWorkingState Implementation

    public bool IsWorking { get; set; }

    public string Message { get; set; } = String.Empty;

    public void NotifyStateChanged() => StateHasChanged();

    #endregion

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    private IReadOnlyList<LicenseInfo>? _licenses;

    protected override async Task OnInitializedAsync()
    {
        using var worker = this.CreateWorkingState(localizer[L.Licenses.Loading]);

        _licenses = await LicenseService.GetLicensesAsync();
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();
}