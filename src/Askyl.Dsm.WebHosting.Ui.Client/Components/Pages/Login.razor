@page "/login"

@implements IWorkingState

@using System.Runtime.InteropServices
@using Askyl.Dsm.WebHosting.Constants.Application
@using Askyl.Dsm.WebHosting.Data.Domain.Authentication
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization
@using Askyl.Dsm.WebHosting.Globalization.Resources
@using Microsoft.Extensions.Localization

@inject IAuthenticationService authService
@inject IDialogService DialogsService
@inject IToastService ToastService
@inject NavigationManager navigation
@inject IStringLocalizer<SharedResource> localizer
@inject ICultureManager cultureManager

<LoadingOverlay WorkingStateComponent="@this" />

<PageTitle>@localizer[L.Login.PageTitle]</PageTitle>

<FluentDialog Modal="true" TrapFocus="true" PreventScroll="true">
    <EditForm Model="@Model" OnValidSubmit="Authenticate">
        <DataAnnotationsValidator />

        <FluentDialogHeader>
            <h2>@localizer[L.Login.DialogTitle]</h2>
        </FluentDialogHeader>

        <FluentStack Orientation="Orientation.Vertical">
            <RealTimeTextField @bind-Value="Model.Login" Label="@localizer[L.Login.LoginLabel]" Class="full-size" Autofocus="true" Name="username" />
            <FluentValidationMessage For="(() => Model.Login)" />
            <RealTimeTextField @bind-Value="Model.Password" TextFieldType="TextFieldType.Password" Label="@localizer[L.Login.PasswordLabel]" Class="full-size" Name="password" />
            <FluentValidationMessage For="(() => Model.Password)" />
            <RealTimeTextField @bind-Value="Model.OtpCode" Label="@localizer[L.Login.OTPLabel]" Class="full-size" Name="otp" />
        </FluentStack>

        <FluentDialogFooter>
            <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Style="flex-grow: 1;">@localizer[L.Common.OK]</FluentButton>
        </FluentDialogFooter>
    </EditForm>
</FluentDialog>

@code
{
    #region IWorkingState Implementation

    public bool IsWorking { get; set; }

    public string Message { get; set; } = String.Empty;

    public void NotifyStateChanged() => StateHasChanged();

    #endregion

    private LoginCredentials Model = new();

    protected override async Task OnInitializedAsync()
    {
        if (!RuntimeInformation.IsOSPlatform(OSPlatform.Linux) && !RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
        {
            DialogsService.ShowError(localizer[L.Error.PlatformNotSupported]);
        }

        var isAuthenticatedResult = await authService.IsAuthenticatedAsync();
        if (isAuthenticatedResult.Success && isAuthenticatedResult.Value == true)
        {
            navigation.NavigateTo(ApplicationConstants.HomePagePath);
        }
    }

    private async Task Authenticate(EditContext context)
    {
        if (IsWorking)
        {
            return;
        }

        using var worker = this.CreateWorkingState(localizer[L.Login.Authenticating]);

        var result = await authService.LoginAsync(Model.Login, Model.Password, Model.OtpCode);

        if (!result.Success || !result.IsAuthenticated)
        {
            // failed - either HTTP call failed or credentials invalid
            var errorMessage = result.Message?.Trim() ?? localizer[L.Error.AuthenticationFailed];
            ToastService.ShowError(errorMessage);
            return;
        }

        // Initialize culture from login response (user preference or system fallback)
        await cultureManager.InitializeFromLoginAsync(result.Culture);

        ToastService.ShowSuccess(localizer[L.Success.AuthenticationSuccessful]);
        navigation.NavigateTo(ApplicationConstants.HomePagePath);
    }
}