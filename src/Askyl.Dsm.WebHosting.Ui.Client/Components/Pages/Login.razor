@page "/login"

@inherits WorkingStateBase

@using Askyl.Dsm.WebHosting.Ui.Client.Components.Patterns.WorkingState
@using System.Runtime.InteropServices
@using Askyl.Dsm.WebHosting.Constants.Application
@using Askyl.Dsm.WebHosting.Data.Domain.Authentication
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization

@inject IAuthenticationService authService
@inject IDialogService DialogsService
@inject IToastService ToastService
@inject NavigationManager navigation
@inject ILocalizer localizer
@inject ICultureManager cultureManager

<LoadingOverlay WorkingStateComponent="@this" OnStateChanged="StateHasChanged" />

<PageTitle>@localizer[LK.Login.PageTitle]</PageTitle>

<FluentDialog Modal="true" TrapFocus="true" PreventScroll="true" Open="true">
    <EditForm Model="@Model" OnValidSubmit="Authenticate">
        <FluentValidator />

        <FluentDialogHeader>
            <h2>@localizer[LK.Login.DialogTitle]</h2>
        </FluentDialogHeader>

        <FluentStack Orientation="Orientation.Vertical">
            <RealTimeTextField @bind-Value="Model.Login" Label="@localizer[LK.Login.LoginLabel]" Class="full-size" Autofocus="true" Name="username" />
            <FluentValidationMessage For="(() => Model.Login)" />
            <RealTimeTextField @bind-Value="Model.Password" TextFieldType="TextFieldType.Password" Label="@localizer[LK.Login.PasswordLabel]" Class="full-size" Name="password" />
            <FluentValidationMessage For="(() => Model.Password)" />
            <RealTimeTextField @bind-Value="Model.OtpCode" Label="@localizer[LK.Login.OTPLabel]" Class="full-size" Name="otp" />
        </FluentStack>

        <FluentDialogFooter>
            <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Fill="Fill.Horizontal">@localizer[LK.Common.OK]</FluentButton>
        </FluentDialogFooter>
    </EditForm>
</FluentDialog>

@code
{
    private LoginCredentials Model = new();

    protected override async Task OnInitializedAsync()
    {
        if (!RuntimeInformation.IsOSPlatform(OSPlatform.Linux) && !RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
        {
            DialogsService.ShowError(localizer[LK.Error.PlatformNotSupported]);
        }

        var isAuthenticatedResult = await authService.IsAuthenticatedAsync();
        if (isAuthenticatedResult.Success && isAuthenticatedResult.Value == true)
        {
            navigation.NavigateTo(ApplicationConstants.HomePagePath);
        }
    }

    private async Task Authenticate(EditContext context)
    {
        if (IsWorking)
        {
            return;
        }

        using var worker = this.CreateWorkingState(localizer[LK.Login.Authenticating]);

        var result = await authService.LoginAsync(Model.Login, Model.Password, Model.OtpCode);

        if (!result.Success || !result.IsAuthenticated)
        {
            // failed - either HTTP call failed or credentials invalid
            var errorMessage = result.Message?.Trim() ?? localizer[LK.Error.AuthenticationFailed];
            ToastService.ShowError(errorMessage);
            return;
        }

        // Initialize culture from login response (user preference or system fallback)
        cultureManager.InitializeFromLogin(result.Culture, result.DateFormat, result.TimeFormat);

        ToastService.ShowSuccess(localizer[LK.Success.AuthenticationSuccessful]);
        navigation.NavigateTo(ApplicationConstants.HomePagePath);
    }
}