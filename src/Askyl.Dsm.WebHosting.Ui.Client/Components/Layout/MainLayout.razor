@inherits LayoutComponentBase

@using System.Reflection
@using Askyl.Dsm.WebHosting.Globalization

@inject ILocalizer localizer

<HeadContent>
    <link rel="stylesheet" href="@Assets["css/app.css"]" />

    <link rel="stylesheet" href="@Assets["css/components/dialogs/file-selection.css"]" />
    <link rel="stylesheet" href="@Assets["css/components/dialogs/aspnet-releases.css"]" />
    <link rel="stylesheet" href="@Assets["css/components/controls/auto-grid.css"]" />
</HeadContent>

<FluentMainLayout class="full-size">
    <Header>
        @localizer[L.Common.ApplicationTitle] @Assembly.GetExecutingAssembly().GetName().Version
    </Header>

    <Body>
        <div class="flex-column-container">
            @Body
        </div>
    </Body>
</FluentMainLayout>

<div id="blazor-error-ui" data-nosnippet>
    <FluentHeader>
        @localizer[L.Common.UnhandledError]
        <FluentSpacer />
        <a href="." class="reload">
            <FluentIcon Value="@(new Icons.Regular.Size32.ArrowCounterclockwise().WithColor(Color.Error))" />
        </a>
        <span class="dismiss">
            <FluentIcon Value="@(new Icons.Regular.Size32.DismissCircle().WithColor(Color.Error))" />
        </span>
    </FluentHeader>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />