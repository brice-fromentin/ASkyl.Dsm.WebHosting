@using System.Globalization
@using Askyl.Dsm.WebHosting.Constants.Application
@using Askyl.Dsm.WebHosting.Constants.Globalization
@using Askyl.Dsm.WebHosting.Data.Contracts
@using Askyl.Dsm.WebHosting.Globalization.Extensions
@using Microsoft.FluentUI.AspNetCore.Components

@inject IHttpContextAccessor HttpContextAccessor
@inject IGlobalizationSettings GlobalizationSettings

<!DOCTYPE html>
<html lang="@(ResolvedCulture.Name)" dir="@(ResolvedCulture.GetTextDirection())">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@(ApplicationConstants.ApplicationUrlSubPath + "/")" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["_content/Microsoft.FluentUI.AspNetCore.Components/css/reboot.css"]" />
    <link rel="stylesheet" href="@Assets["Askyl.Dsm.WebHosting.Ui.styles.css"]" />

    <ImportMap />

    <script src="@Assets["js/tree-navigation.js"]"></script>

    <link rel="icon" type="image/svg+xml" href="images/adwh-logo.svg" sizes="any">
    <link rel="icon" type="image/png" href="images/favicon.png" sizes="any" />

    <HeadOutlet @rendermode="InteractiveWebAssembly" />
</head>

<body>
    <FluentDesignTheme Mode="@DesignThemeModes.System" />

    <FluentLayout Class="full-size">
        <Routes @rendermode="@wasm" />
    </FluentLayout>
    
    <script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
    <script>
        Blazor.start({
            webAssembly: {
                configureRuntime: dotnet => {
                    dotnet.withEnvironmentVariable(
                        '@GlobalizationConstants.SupportedCulturesEnvironmentVariable',
                        '@((MarkupString)GlobalizationSettings.SupportedCultureNamesJson)'
                    );
                    dotnet.withEnvironmentVariable(
                        '@GlobalizationConstants.SystemCultureEnvironmentVariable',
                        '@(GlobalizationSettings.SystemCulture ?? "")'
                    );
                }
            },
            loadAllGlobalizationData: true
        });
    </script>
</body>

</html>

@code
{
    IComponentRenderMode wasm = new InteractiveWebAssemblyRenderMode(false);

    private static readonly CultureInfo[] NeutralCultures = CultureInfo.GetCultures(CultureTypes.NeutralCultures);

    private CultureInfo? _resolvedCulture;

    private CultureInfo ResolvedCulture => _resolvedCulture ??= ResolveCulture();

    private CultureInfo ResolveCulture()
    {
        // Priority 1: DSM system culture (from /etc/synoinfo.conf)
        if (!String.IsNullOrWhiteSpace(GlobalizationSettings.SystemCulture))
        {
            try
            {
                return new CultureInfo(GlobalizationSettings.SystemCulture);
            }
            catch (CultureNotFoundException)
            {
                // Fall through to Accept-Language parsing
            }
        }

        // Priority 2: parse Accept-Language header directly
        // IRequestCultureFeature doesn't match neutral languages (e.g. "fr" -> "fr-FR"),
        // so we parse the header ourselves and match against supported cultures.
        var acceptLanguage = HttpContextAccessor?.HttpContext?.Request.Headers[GlobalizationConstants.AcceptLanguageHeader].ToString();

        if (!String.IsNullOrWhiteSpace(acceptLanguage))
        {
            var language = acceptLanguage.Split(',')[0].Split(';')[0].Trim();

            // Handle neutral languages (e.g. "fr") — match to supported culture
            if (GlobalizationSettings.SupportedCultures.Any(c => String.Equals(c.TwoLetterISOLanguageName, language, StringComparison.OrdinalIgnoreCase)))
            {
                return new CultureInfo(language);
            }

            // Return the first 2 chars if it looks like a valid BCP-47 tag
            if (language.Length >= 2 && NeutralCultures.Any(c => String.Equals(c.TwoLetterISOLanguageName, language, StringComparison.OrdinalIgnoreCase)))
            {
                return new CultureInfo(language);
            }
        }

        return GlobalizationConstants.DefaultCultureInfo;
    }
}